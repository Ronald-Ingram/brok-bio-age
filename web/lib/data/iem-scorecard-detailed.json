  "extensibility": {
    "description": "Users or BROK agents can add, remove, or re-weight any sub-factor. New factors should include a name, default_weight (1-5), and ideal_score.",
    "allowed_operations": ["add_factor", "modify_weight", "disable_factor", "add_custom_category"]
  },
  "integration_notes": {
    "banking_use_case": "Map standard financial ratios (DSCR, LTV, DTI/TDSR, Debt Yield, etc.) into Financial and Risk categories. Credit Risk and Loan Loss Provision factors already exist natively.",
    "brok_agent": "This model replaces the simple 4-bucket version for high-stakes decisions (loan origination, Star Bank approvals, investment decisions)."
