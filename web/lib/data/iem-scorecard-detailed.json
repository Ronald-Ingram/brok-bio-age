{
  "framework": "IEM_Scorecard_Detailed_v1",
  "version": "2026-05",
  "description": "Full Ingram Evaluation Matrix (IEM) Scorecard model with 49 default sub-factors. Based on operational spreadsheet implementation. Categories have fixed weights. Sub-factors have default weights and can be adapted or extended by users or BROK agents.",
  "total_factors": 49,
  "scoring_scale": "1-5",
  "ideal_score_per_factor": 5,
  "normalization": "Category scores are normalized against ideal weighted total, then combined using category_weights.",
  "category_weights": {
    "Financial": 0.30,
    "Feasibility": 0.20,
    "Strategic": 0.30,
    "Risk": 0.20
  },
  "scoring_principles": [
    "Relativistic Scoring: Scores (1-5) are relative to benchmarks and context.",
    "Confidence Weighting: Adjust scores based on data quality and certainty.",
    "Contextual Anchoring: Weights and interpretation can shift based on project type (e.g. Visionary vs Regulatory vs Credit Decision)."
  ],
  "categories": {
